<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PromptShell.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="PromptShell.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PromptShell"
        Background="#1E1E1E">

    <Grid RowDefinitions="*, Auto, Auto" Margin="15">
        
        <ScrollViewer Grid.Row="0" Margin="0,0,0,15" VerticalScrollBarVisibility="Auto">
            <TextBlock Text="{Binding TerminalOutput}" 
                       Foreground="#A9B7C6" 
                       FontFamily="Courier New, Consolas, monospace" 
                       FontSize="13"
                       TextWrapping="Wrap"/>
        </ScrollViewer>

        <Border Grid.Row="1" 
                Background="#332B00" 
                BorderBrush="#8A7300" 
                BorderThickness="1" 
                CornerRadius="4" 
                Padding="15,10" 
                Margin="0,0,0,15"
                IsVisible="{Binding IsPendingApproval}">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Do you want to execute this command?" Foreground="#FFD700" FontWeight="Bold"/>
                    <TextBlock Text="{Binding PendingCommand}" Foreground="White" FontFamily="Courier New, monospace" Margin="0,5,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" 
                        Content="Yes, Execute" 
                        Command="{Binding ApproveCommandCommand}" 
                        Background="#28A745" 
                        Foreground="White" 
                        Margin="10,0,0,0" 
                        Padding="15,8"/>
                <Button Grid.Column="2" 
                        Content="No, Cancel" 
                        Command="{Binding RejectCommandCommand}" 
                        Background="#DC3545" 
                        Foreground="White" 
                        Margin="10,0,0,0" 
                        Padding="15,8"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" IsEnabled="{Binding !IsPendingApproval}">
            <TextBox Grid.Column="0" 
                     Text="{Binding InputCommand, Mode=TwoWay}" 
                     Watermark="Ask me to do something (e.g. 'show files' or 'create a test folder')..."
                     Background="#2B2B2B"
                     Foreground="White"
                     BorderBrush="#3C3F41"
                     VerticalContentAlignment="Center">
                <TextBox.KeyBindings>
                    <KeyBinding Gesture="Enter" Command="{Binding ExecuteTerminalCommandCommand}"/>
                </TextBox.KeyBindings>
            </TextBox>
            
            <Button Grid.Column="1" 
                    Content="Run" 
                    Command="{Binding ExecuteTerminalCommandCommand}"
                    Margin="10,0,0,0"
                    Padding="15,0"
                    Background="#4B6EAF"
                    Foreground="White"
                    VerticalAlignment="Stretch"
                    VerticalContentAlignment="Center"/>
        </Grid>
    </Grid>
</Window>