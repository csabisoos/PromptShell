<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PromptShell.ViewModels"
        xmlns:local="using:PromptShell.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="PromptShell.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PromptShell"
        Background="#121214">

    <Window.Resources>
        <local:StringComparisonConverter x:Key="StringComparisonConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto, *, Auto" Background="#121214" Margin="0">
        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A1A1E" BorderBrush="#27272C" BorderThickness="0,0,0,1" Padding="24,16">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📁" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Active Folder" Foreground="#8E8E93" FontSize="11"/>
                        <TextBlock Text="{Binding CurrentWorkingDirectory}" Foreground="#A9A9B3" FontSize="12" FontFamily="Cascadia Code, Courier New" TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="2" Name="BrowseFolderButton" Content="Browse Folder..." Click="BrowseFolderButton_OnClick" Background="#007AFF" Foreground="White" Padding="12,8" CornerRadius="8" FontSize="11" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- CHAT -->
        <Border Grid.Row="1" Background="#121214" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24,16">
                <ItemsControl ItemsSource="{Binding ChatTimeline}" Background="Transparent">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4,0,4">
                                <!-- USER -->
                                <StackPanel HorizontalAlignment="Right" MaxWidth="650" IsVisible="{Binding Sender, Converter={StaticResource StringComparisonConverter}, ConverterParameter=User}">
                                    <Border Background="#007AFF" CornerRadius="14" Padding="14,10">
                                        <StackPanel MaxWidth="600" Spacing="6">
                                            <TextBlock Text="{Binding Message}" Foreground="#FFFFFF" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Timestamp}" Foreground="#E0E0E0" FontSize="9"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- AI -->
                                <StackPanel HorizontalAlignment="Left" MaxWidth="650" IsVisible="{Binding Sender, Converter={StaticResource StringComparisonConverter}, ConverterParameter=AI}">
                                    <Border Background="#1A1A1E" BorderBrush="#27272C" BorderThickness="1" CornerRadius="14" Padding="14,10">
                                        <StackPanel MaxWidth="600" Spacing="8">
                                            <TextBlock Text="{Binding Message}" Foreground="#F0F0F0" FontSize="13" TextWrapping="Wrap"/>
                                            <Expander IsVisible="{Binding HasTechnicalDetails}" Background="Transparent" Padding="0">
                                                <Expander.Header>
                                                    <TextBlock Text="📋 Details" Foreground="#8E8E93" FontSize="10"/>
                                                </Expander.Header>
                                                <Border Background="#0F0F11" BorderBrush="#27272C" BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,6,0,0">
                                                    <TextBlock Text="{Binding RawTechnicalDetails}" Foreground="#4FD585" FontSize="9" FontFamily="Cascadia Code, Courier New" TextWrapping="Wrap"/>
                                                </Border>
                                            </Expander>
                                            <TextBlock Text="{Binding Timestamp}" Foreground="#8E8E93" FontSize="9"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- ACTION -->
                                <StackPanel HorizontalAlignment="Left" MaxWidth="650" IsVisible="{Binding Sender, Converter={StaticResource StringComparisonConverter}, ConverterParameter=ActionCard}">
                                    <Border Background="#1A1A1E" BorderBrush="#D19A66" BorderThickness="2" CornerRadius="14" Padding="14,12">
                                        <StackPanel MaxWidth="600" Spacing="10">
                                            <TextBlock Text="{Binding Message}" Foreground="#F0F0F0" FontSize="13" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <Border Background="#0F0F11" BorderBrush="#27272C" BorderThickness="1" CornerRadius="6" Padding="10,8">
                                                <TextBlock Text="{Binding PendingCommand}" Foreground="#A9A9B3" FontSize="11" FontFamily="Cascadia Code, Courier New" TextWrapping="Wrap"/>
                                            </Border>
                                            <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsActionPending}">
                                                <Button Content="Approve &amp; Run" 
                                                        Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).ApproveCommandCommand}" 
                                                        Background="#34C759" Foreground="Black" FontWeight="Bold" Padding="15,6" CornerRadius="4"/>
    
                                                <Button Content="Reject" 
                                                        Command="{Binding $parent[ListBox].((vm:MainWindowViewModel)DataContext).RejectCommandCommand}" 
                                                        Background="#FF3B30" Foreground="White" Padding="15,6" CornerRadius="4"/>
                                            </StackPanel>
                                            <TextBlock IsVisible="{Binding !IsActionPending}" Text="✓ Completed" Foreground="#8E8E93" FontSize="10" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- SYSTEM -->
                                <TextBlock HorizontalAlignment="Center" IsVisible="{Binding Sender, Converter={StaticResource StringComparisonConverter}, ConverterParameter=System}" Text="{Binding Message}" Foreground="#8E8E93" FontSize="11" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- INPUT -->
        <Border Grid.Row="2" Background="#1A1A1E" BorderBrush="#27272C" BorderThickness="0,1,0,0" Padding="24,14">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <TextBox Grid.Column="0" Text="{Binding InputCommand, Mode=TwoWay}" PlaceholderText="Ask anything..." Background="#0F0F11" Foreground="#F0F0F0" BorderBrush="#27272C" BorderThickness="1" CornerRadius="10" Padding="14,10" FontSize="13" Height="44" VerticalContentAlignment="Center">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding ExecuteTerminalCommandCommand}"/>
                        <KeyBinding Gesture="Up" Command="{Binding NavigateHistoryUpCommand}"/>
                        <KeyBinding Gesture="Down" Command="{Binding NavigateHistoryDownCommand}"/>
                    </TextBox.KeyBindings>
                </TextBox>
                <Button Grid.Column="1" Content="Clear" Background="Transparent" BorderBrush="#8E8E93" BorderThickness="1" Padding="12,8" CornerRadius="6" FontSize="11" Margin="10,0,0,0"/>
                <Button Grid.Column="2" Content="Send" Command="{Binding ExecuteTerminalCommandCommand}" Foreground="#FFFFFF" Background="#007AFF" BorderThickness="0" Padding="18,8" CornerRadius="6" FontSize="12" FontWeight="SemiBold" Margin="8,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
